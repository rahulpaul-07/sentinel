# ---- Sentinel configuration (template) ----
# Copy this to a file named `.env` and fill in real values.
# `.env` is git-ignored, so real secrets never get committed.

# Which AI model to use (any string litellm understands):
#   Local (Ollama):  ollama/llama3.2
#   Anthropic:       claude-sonnet-5   (+ set ANTHROPIC_API_KEY)
#   OpenAI:          gpt-4o-mini       (+ set OPENAI_API_KEY)
SENTINEL_MODEL=ollama/llama3.2

# Only needed for hosted providers (leave out for local Ollama):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=